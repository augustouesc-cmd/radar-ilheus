# ── Banco de dados (Railway PostgreSQL) ──────────────────────
# Cole a URL gerada pelo Railway no painel do serviço PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Porta local ───────────────────────────────────────────────
PORT=3000

# ── API de clima ──────────────────────────────────────────────
OPENWEATHER_KEY=sua_chave_aqui
